# ══════════════════════════════════════════════════════
#  NMB Connect Backend — Environment Variables
# ══════════════════════════════════════════════════════

# Your Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (get from @userinfobot)
ADMIN_CHAT_ID=your_chat_id_here

# Full public URL to this server (your Render URL)
SERVER_URL=https://your-render-url.onrender.com

# Secret key for signing tokens — use any long random string
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=change_this_to_a_long_random_string

# Port (Render sets this automatically)
PORT=3000

# Allowed origins for CORS (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-url.com

# Optional: OTP settings
OTP_EXPIRY_SECONDS=120
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
